generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ANCIAO
  PUBLICADOR
}

enum CongregationStatus {
  PENDING
  ACTIVE
  BLOCKED
}

model Congregation {
  id          String             @id @default(cuid())
  name        String
  jwEmail     String
  state       String             // UF, ex: "SP"
  city        String
  status      CongregationStatus @default(PENDING)
  createdById String
  createdBy   User               @relation("CongregationCreatedBy", fields: [createdById], references: [id])
  members     User[]             @relation("CongregationMembers")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                    String             @id @default(cuid())
  email                 String             @unique
  passwordHash          String
  role                  Role               @default(PUBLICADOR)
  isBlocked             Boolean            @default(false)
  congregationId        String?
  congregation          Congregation?      @relation("CongregationMembers", fields: [congregationId], references: [id])
  congregationsCreated  Congregation[]     @relation("CongregationCreatedBy")
  pushSubscriptions     PushSubscription[]
  pioneerReports        PioneerReport[]
  lastSeenAt            DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  revisits              Revisit[]

  @@index([congregationId])
}

model PioneerReport {
  id           String   @id @default(cuid())
  userId       String
  date         String   // "YYYY-MM-DD"
  hours        Int      @default(0)
  minutes      Int      @default(0)
  creditHours  Int      @default(0)
  bibleStudies Int      @default(0)
  goalHours    Int      @default(2)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model Revisit {
  id        String   @id @default(cuid())
  userId    String
  name      String
  address   String
  latitude  Float
  longitude Float
  isActive  Boolean  @default(true)
  notes     String?
  visitDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([latitude, longitude])
}
