generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ANCIAO
  PUBLICADOR
  SERVO_DE_CAMPO
}

enum TerritoryType {
  IMAGE
  STREETS
}

enum HouseVisitStatus {
  OK
  FAIL
}

enum CongregationStatus {
  PENDING
  ACTIVE
  BLOCKED
  REJECTED
}

model Congregation {
  id          String             @id @default(cuid())
  name        String
  jwEmail     String
  state       String             // UF, ex: "SP"
  city        String
  status      CongregationStatus @default(PENDING)
  rejectionReason String?
  createdById String
  createdBy   User               @relation("CongregationCreatedBy", fields: [createdById], references: [id])
  members     User[]             @relation("CongregationMembers")
  territories Territory[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                    String             @id @default(cuid())
  email                 String             @unique
  name                  String?
  passwordHash          String
  firebaseUid           String?            @unique
  role                  Role               @default(PUBLICADOR)
  isBlocked             Boolean            @default(false)
  congregationId        String?
  congregation          Congregation?      @relation("CongregationMembers", fields: [congregationId], references: [id])
  congregationsCreated  Congregation[]     @relation("CongregationCreatedBy")
  pushSubscriptions     PushSubscription[]
  pioneerReports        PioneerReport[]
  lastSeenAt            DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  revisits              Revisit[]
  houseVisits           HouseVisit[]

  @@index([congregationId])
}

model PioneerReport {
  id           String   @id @default(cuid())
  userId       String
  date         String   // "YYYY-MM-DD"
  hours        Int      @default(0)
  minutes      Int      @default(0)
  creditHours  Int      @default(0)
  bibleStudies Int      @default(0)
  goalHours    Int      @default(2)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model Revisit {
  id        String   @id @default(cuid())
  userId    String
  name      String
  address   String
  latitude  Float
  longitude Float
  isActive  Boolean  @default(true)
  notes     String?
  visitDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([latitude, longitude])
}

// ============================================================
// Territórios (migrado do Firebase/Firestore - territorios-utinga)
// ============================================================

model Territory {
  id             String        @id @default(cuid())
  firebaseId     String?       @unique  // ID original do Firestore (número como string)
  number         Int           @unique
  label          String?                // Rótulo customizado: "A", "Norte", "1", etc.
  territoryType  TerritoryType @default(STREETS)
  imageUrl       String?                // Caminho da imagem (territories IMAGE)
  color          String        @default("#cccccc")
  hidden         Boolean       @default(false)
  lastUpdate     DateTime?
  congregationId String?
  congregation   Congregation? @relation(fields: [congregationId], references: [id])
  streets        Street[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([congregationId])
}

model Street {
  id          String    @id              // UUID original do Firestore
  name        String
  lastUpdate  DateTime?
  territoryId String
  territory   Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  houses      House[]

  @@index([territoryId])
}

model House {
  id          String       @id              // UUID original do Firestore
  number      String
  observation String?
  phones      Json         @default("[]")
  streetId    String
  street      Street       @relation(fields: [streetId], references: [id], onDelete: Cascade)
  visits      HouseVisit[]

  @@index([streetId])
}

model HouseVisit {
  id              String           @id @default(cuid())
  houseId         String
  house           House            @relation(fields: [houseId], references: [id], onDelete: Cascade)
  status          HouseVisitStatus
  visitedAt       DateTime
  firebaseUserUid String?          // Firebase UID para dados históricos migrados
  userId          String?
  user            User?            @relation(fields: [userId], references: [id])
  createdAt       DateTime         @default(now())

  @@index([houseId])
  @@index([userId])
}
