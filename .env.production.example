# App
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://www.pregadores.site
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=720788025025-q9jjbaneeivh7s77c55cgv5ss95dr06p.apps.googleusercontent.com
GOOGLE_CLIENT_ID=720788025025-q9jjbaneeivh7s77c55cgv5ss95dr06p.apps.googleusercontent.com

# Push Notifications (VAPID)
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Deve ser igual ao VAPID_PUBLIC_KEY para o navegador conseguir assinar
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
ADMIN_EMAIL=admin@pregadores.site

# Database (recomendado: PostgreSQL gerenciado)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/pregadores?schema=public

# JWT (gere segredos fortes, no minimo 32 caracteres)
JWT_SECRET=troque-por-um-segredo-forte-com-mais-de-32-caracteres
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte-com-mais-de-32-caracteres
